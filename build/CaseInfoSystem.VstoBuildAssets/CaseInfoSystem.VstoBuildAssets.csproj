<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
    <PackageId>CaseInfoSystem.VstoBuildAssets</PackageId>
    <Version>1.0.2</Version>
    <Authors>CaseInfoSystem</Authors>
    <Description>Local build asset package for VSTO projects on developer machines with Visual Studio VSTO reference assemblies installed.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <VisualStudioVstoReferenceDir Condition="'$(VisualStudioVstoReferenceDir)' == ''">C:\Program Files\Microsoft Visual Studio\18\Community\Common7\IDE\ReferenceAssemblies\v4.0</VisualStudioVstoReferenceDir>
    <OfficePrimaryInteropDir Condition="'$(OfficePrimaryInteropDir)' == ''">C:\Program Files\Microsoft Visual Studio\18\Community\Common7\IDE\ReferenceAssemblies\v4.0\Office15</OfficePrimaryInteropDir>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="build\CaseInfoSystem.VstoBuildAssets.props" Pack="true" PackagePath="build\" />
    <None Include="build\CaseInfoSystem.VstoBuildAssets.targets" Pack="true" PackagePath="build\" />
    <None Include="$(OfficePrimaryInteropDir)\Office.dll" Pack="true" PackagePath="lib\net48\" Visible="false" Condition="Exists('$(OfficePrimaryInteropDir)\Office.dll')" />
    <None Include="$(VisualStudioVstoReferenceDir)\Microsoft.Office.Tools.v4.0.Framework.dll" Pack="true" PackagePath="lib\net48\" Visible="false" Condition="Exists('$(VisualStudioVstoReferenceDir)\Microsoft.Office.Tools.v4.0.Framework.dll')" />
    <None Include="$(VisualStudioVstoReferenceDir)\Microsoft.VisualStudio.Tools.Applications.Runtime.dll" Pack="true" PackagePath="lib\net48\" Visible="false" Condition="Exists('$(VisualStudioVstoReferenceDir)\Microsoft.VisualStudio.Tools.Applications.Runtime.dll')" />
    <None Include="$(VisualStudioVstoReferenceDir)\Microsoft.Office.Tools.dll" Pack="true" PackagePath="lib\net48\" Visible="false" Condition="Exists('$(VisualStudioVstoReferenceDir)\Microsoft.Office.Tools.dll')" />
    <None Include="$(VisualStudioVstoReferenceDir)\Microsoft.Office.Tools.Common.dll" Pack="true" PackagePath="lib\net48\" Visible="false" Condition="Exists('$(VisualStudioVstoReferenceDir)\Microsoft.Office.Tools.Common.dll')" />
    <None Include="$(VisualStudioVstoReferenceDir)\Microsoft.Office.Tools.Excel.dll" Pack="true" PackagePath="lib\net48\" Visible="false" Condition="Exists('$(VisualStudioVstoReferenceDir)\Microsoft.Office.Tools.Excel.dll')" />
    <None Include="$(VisualStudioVstoReferenceDir)\Microsoft.Office.Tools.Word.dll" Pack="true" PackagePath="lib\net48\" Visible="false" Condition="Exists('$(VisualStudioVstoReferenceDir)\Microsoft.Office.Tools.Word.dll')" />
    <None Include="$(VisualStudioVstoReferenceDir)\Microsoft.Office.Tools.Common.v4.0.Utilities.dll" Pack="true" PackagePath="lib\net48\" Visible="false" Condition="Exists('$(VisualStudioVstoReferenceDir)\Microsoft.Office.Tools.Common.v4.0.Utilities.dll')" />
  </ItemGroup>
</Project>
