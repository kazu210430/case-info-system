<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
    <PackageId>Microsoft.Office.Interop.Word</PackageId>
    <Version>15.0.4797.1004</Version>
    <Authors>Microsoft</Authors>
    <Description>Local package mirror for Microsoft.Office.Interop.Word 15.0.4797.1004 used by the VSTO build.</Description>
    <Office15PiaDir Condition="'$(Office15PiaDir)' == ''">C:\Program Files (x86)\Microsoft Visual Studio\Shared\Visual Studio Tools for Office\PIA\Office15</Office15PiaDir>
  </PropertyGroup>

  <ItemGroup>
    <None Include="build\Microsoft.Office.Interop.Word.props"
          Pack="true"
          PackagePath="build\"
          Visible="false" />
    <None Include="$(Office15PiaDir)\Microsoft.Office.Interop.Word.dll"
          Pack="true"
          PackagePath="lib\net20\"
          Visible="false"
          Condition="Exists('$(Office15PiaDir)\Microsoft.Office.Interop.Word.dll')" />
  </ItemGroup>
</Project>
